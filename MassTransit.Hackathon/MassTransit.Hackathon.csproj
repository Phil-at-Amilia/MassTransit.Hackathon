<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>MassTransit.Hackathon</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!--
      MassTransit.RabbitMQ bundles:
        - MassTransit (core bus abstractions)
        - RabbitMQ.Client (AMQP transport)
        - Microsoft.Extensions.Hosting integration
    -->
    <PackageReference Include="MassTransit.RabbitMQ" Version="8.3.6" />
    <!-- Provides Host.CreateDefaultBuilder and the Generic Host runtime -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
  </ItemGroup>

</Project>
